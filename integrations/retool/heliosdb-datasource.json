{
  "name": "HeliosDB",
  "version": "2.8.0",
  "type": "rest_api",
  "description": "AI-native embedded database with vector search, branching, and agent memory",

  "connection": {
    "fields": [
      {
        "name": "baseUrl",
        "label": "HeliosDB URL",
        "type": "string",
        "required": true,
        "placeholder": "https://your-instance.example.com",
        "description": "Your HeliosDB instance URL"
      },
      {
        "name": "apiKey",
        "label": "API Key",
        "type": "password",
        "required": false,
        "description": "API key for authentication (if enabled)"
      }
    ],
    "test": {
      "method": "GET",
      "path": "/health"
    }
  },

  "authentication": {
    "type": "header",
    "header": "X-API-Key",
    "value": "{{apiKey}}"
  },

  "queries": {
    "executeQuery": {
      "name": "Execute SQL Query",
      "description": "Execute a SQL query against HeliosDB",
      "method": "POST",
      "path": "/v1/branches/{{branch}}/query",
      "parameters": [
        {
          "name": "sql",
          "label": "SQL Query",
          "type": "sql",
          "required": true
        },
        {
          "name": "branch",
          "label": "Branch",
          "type": "string",
          "default": "main"
        },
        {
          "name": "params",
          "label": "Query Parameters",
          "type": "json",
          "default": "[]"
        }
      ],
      "body": {
        "sql": "{{sql}}",
        "params": "{{params}}"
      },
      "transform": "return data.rows;"
    },

    "listTables": {
      "name": "List Tables",
      "description": "Get all tables in the database",
      "method": "POST",
      "path": "/v1/branches/{{branch}}/query",
      "parameters": [
        {
          "name": "branch",
          "label": "Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "sql": "SELECT table_name, table_type FROM information_schema.tables WHERE table_schema = 'public' ORDER BY table_name",
        "params": []
      },
      "transform": "return data.rows;"
    },

    "getTableSchema": {
      "name": "Get Table Schema",
      "description": "Get column information for a table",
      "method": "POST",
      "path": "/v1/branches/{{branch}}/query",
      "parameters": [
        {
          "name": "table",
          "label": "Table Name",
          "type": "string",
          "required": true
        },
        {
          "name": "branch",
          "label": "Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "sql": "SELECT column_name, data_type, is_nullable, column_default FROM information_schema.columns WHERE table_name = $1 ORDER BY ordinal_position",
        "params": ["{{table}}"]
      },
      "transform": "return data.rows;"
    },

    "insertRow": {
      "name": "Insert Row",
      "description": "Insert a new row into a table",
      "method": "POST",
      "path": "/v1/branches/{{branch}}/tables/{{table}}/data",
      "parameters": [
        {
          "name": "table",
          "label": "Table Name",
          "type": "string",
          "required": true
        },
        {
          "name": "data",
          "label": "Row Data",
          "type": "json",
          "required": true,
          "description": "JSON object with column values"
        },
        {
          "name": "branch",
          "label": "Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "rows": ["{{data}}"]
      }
    },

    "updateRows": {
      "name": "Update Rows",
      "description": "Update rows matching a condition",
      "method": "POST",
      "path": "/v1/branches/{{branch}}/query",
      "parameters": [
        {
          "name": "table",
          "label": "Table Name",
          "type": "string",
          "required": true
        },
        {
          "name": "set",
          "label": "SET Clause",
          "type": "string",
          "required": true,
          "placeholder": "column1 = 'value1', column2 = 'value2'"
        },
        {
          "name": "where",
          "label": "WHERE Clause",
          "type": "string",
          "required": true,
          "placeholder": "id = 1"
        },
        {
          "name": "branch",
          "label": "Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "sql": "UPDATE {{table}} SET {{set}} WHERE {{where}}",
        "params": []
      }
    },

    "deleteRows": {
      "name": "Delete Rows",
      "description": "Delete rows matching a condition",
      "method": "POST",
      "path": "/v1/branches/{{branch}}/query",
      "parameters": [
        {
          "name": "table",
          "label": "Table Name",
          "type": "string",
          "required": true
        },
        {
          "name": "where",
          "label": "WHERE Clause",
          "type": "string",
          "required": true,
          "placeholder": "id = 1"
        },
        {
          "name": "branch",
          "label": "Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "sql": "DELETE FROM {{table}} WHERE {{where}}",
        "params": []
      }
    },

    "vectorSearch": {
      "name": "Vector Search",
      "description": "Search for similar documents using semantic similarity",
      "method": "POST",
      "path": "/v1/vectors/stores/{{storeName}}/search/text",
      "parameters": [
        {
          "name": "storeName",
          "label": "Vector Store",
          "type": "string",
          "required": true
        },
        {
          "name": "query",
          "label": "Search Query",
          "type": "string",
          "required": true
        },
        {
          "name": "topK",
          "label": "Max Results",
          "type": "number",
          "default": 10
        },
        {
          "name": "minScore",
          "label": "Minimum Score",
          "type": "number",
          "default": 0.7
        },
        {
          "name": "filter",
          "label": "Metadata Filter",
          "type": "json",
          "default": "{}"
        }
      ],
      "body": {
        "text": "{{query}}",
        "top_k": "{{topK}}",
        "min_score": "{{minScore}}",
        "filter": "{{filter}}"
      },
      "transform": "return data.results;"
    },

    "storeDocument": {
      "name": "Store Document",
      "description": "Store text with automatic vector embedding",
      "method": "POST",
      "path": "/v1/vectors/stores/{{storeName}}/texts",
      "parameters": [
        {
          "name": "storeName",
          "label": "Vector Store",
          "type": "string",
          "required": true
        },
        {
          "name": "text",
          "label": "Text Content",
          "type": "text",
          "required": true
        },
        {
          "name": "metadata",
          "label": "Metadata",
          "type": "json",
          "default": "{}"
        }
      ],
      "body": {
        "texts": ["{{text}}"],
        "metadatas": ["{{metadata}}"]
      }
    },

    "listVectorStores": {
      "name": "List Vector Stores",
      "description": "Get all vector stores",
      "method": "GET",
      "path": "/v1/vectors/stores",
      "transform": "return data.data;"
    },

    "createVectorStore": {
      "name": "Create Vector Store",
      "description": "Create a new vector store",
      "method": "POST",
      "path": "/v1/vectors/stores",
      "parameters": [
        {
          "name": "name",
          "label": "Store Name",
          "type": "string",
          "required": true
        },
        {
          "name": "dimensions",
          "label": "Vector Dimensions",
          "type": "number",
          "default": 1536
        },
        {
          "name": "metric",
          "label": "Distance Metric",
          "type": "select",
          "options": ["cosine", "euclidean", "dot"],
          "default": "cosine"
        }
      ],
      "body": {
        "name": "{{name}}",
        "dimensions": "{{dimensions}}",
        "metric": "{{metric}}"
      }
    },

    "agentMemoryLoad": {
      "name": "Load Agent Memory",
      "description": "Load conversation history for an agent session",
      "method": "GET",
      "path": "/v1/agents/memory/{{sessionId}}/messages",
      "parameters": [
        {
          "name": "sessionId",
          "label": "Session ID",
          "type": "string",
          "required": true
        },
        {
          "name": "limit",
          "label": "Message Limit",
          "type": "number",
          "default": 50
        }
      ],
      "queryParams": {
        "limit": "{{limit}}"
      },
      "transform": "return data.messages;"
    },

    "agentMemorySave": {
      "name": "Save Agent Memory",
      "description": "Save a message to agent conversation memory",
      "method": "POST",
      "path": "/v1/agents/memory/{{sessionId}}/add",
      "parameters": [
        {
          "name": "sessionId",
          "label": "Session ID",
          "type": "string",
          "required": true
        },
        {
          "name": "role",
          "label": "Role",
          "type": "select",
          "options": ["user", "assistant", "system"],
          "required": true
        },
        {
          "name": "content",
          "label": "Message Content",
          "type": "text",
          "required": true
        }
      ],
      "body": {
        "role": "{{role}}",
        "content": "{{content}}"
      }
    },

    "agentMemorySearch": {
      "name": "Search Agent Memory",
      "description": "Search agent memory semantically",
      "method": "POST",
      "path": "/v1/agents/memory/{{sessionId}}/search",
      "parameters": [
        {
          "name": "sessionId",
          "label": "Session ID",
          "type": "string",
          "required": true
        },
        {
          "name": "query",
          "label": "Search Query",
          "type": "string",
          "required": true
        },
        {
          "name": "topK",
          "label": "Max Results",
          "type": "number",
          "default": 10
        }
      ],
      "body": {
        "query": "{{query}}",
        "top_k": "{{topK}}"
      },
      "transform": "return data.results;"
    },

    "listBranches": {
      "name": "List Branches",
      "description": "Get all database branches",
      "method": "GET",
      "path": "/v1/branches",
      "transform": "return data.branches;"
    },

    "createBranch": {
      "name": "Create Branch",
      "description": "Create a new database branch",
      "method": "POST",
      "path": "/v1/branches",
      "parameters": [
        {
          "name": "name",
          "label": "Branch Name",
          "type": "string",
          "required": true
        },
        {
          "name": "fromBranch",
          "label": "Source Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "name": "{{name}}",
        "from_branch": "{{fromBranch}}"
      }
    },

    "mergeBranch": {
      "name": "Merge Branch",
      "description": "Merge a branch into another",
      "method": "POST",
      "path": "/v1/branches/{{sourceBranch}}/merge",
      "parameters": [
        {
          "name": "sourceBranch",
          "label": "Source Branch",
          "type": "string",
          "required": true
        },
        {
          "name": "targetBranch",
          "label": "Target Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "target": "{{targetBranch}}"
      }
    },

    "timeTravelQuery": {
      "name": "Time Travel Query",
      "description": "Query data at a specific point in time",
      "method": "POST",
      "path": "/v1/branches/{{branch}}/query",
      "parameters": [
        {
          "name": "sql",
          "label": "SQL Query",
          "type": "sql",
          "required": true
        },
        {
          "name": "timestamp",
          "label": "Point in Time",
          "type": "datetime",
          "required": true
        },
        {
          "name": "branch",
          "label": "Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "sql": "{{sql}}",
        "as_of_timestamp": "{{timestamp}}"
      },
      "transform": "return data.rows;"
    },

    "chatCompletion": {
      "name": "RAG Chat Completion",
      "description": "Chat with RAG-enabled response using your data",
      "method": "POST",
      "path": "/v1/chat/completions",
      "parameters": [
        {
          "name": "message",
          "label": "User Message",
          "type": "text",
          "required": true
        },
        {
          "name": "vectorStore",
          "label": "Vector Store (for RAG)",
          "type": "string"
        },
        {
          "name": "systemPrompt",
          "label": "System Prompt",
          "type": "text",
          "default": "You are a helpful assistant."
        }
      ],
      "body": {
        "messages": [
          {"role": "system", "content": "{{systemPrompt}}"},
          {"role": "user", "content": "{{message}}"}
        ],
        "rag": {
          "enabled": true,
          "store": "{{vectorStore}}"
        }
      },
      "transform": "return data.choices[0].message;"
    },

    "naturalLanguageQuery": {
      "name": "Natural Language Query",
      "description": "Query database using natural language",
      "method": "POST",
      "path": "/v1/nl/query",
      "parameters": [
        {
          "name": "question",
          "label": "Question",
          "type": "text",
          "required": true,
          "placeholder": "What are the top 10 customers by revenue?"
        },
        {
          "name": "branch",
          "label": "Branch",
          "type": "string",
          "default": "main"
        }
      ],
      "body": {
        "question": "{{question}}",
        "branch": "{{branch}}"
      },
      "transform": "return { sql: data.sql, results: data.rows };"
    }
  },

  "gui_queries": {
    "table_browser": {
      "list_tables": "listTables",
      "get_schema": "getTableSchema",
      "execute": "executeQuery"
    }
  }
}
