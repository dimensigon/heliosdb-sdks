{
  "name": "heliosdb",
  "label": "HeliosDB",
  "version": "2.8.0",
  "description": "Connect to HeliosDB - AI-native embedded database with vector search, branching, and agent memory.",
  "base_url": "{{connection.url}}",
  "icon": "data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCI+PHBhdGggZD0iTTEyIDJDNi40OCAyIDIgNi40OCAyIDEyczQuNDggMTAgMTAgMTAgMTAtNC40OCAxMC0xMFMxNy41MiAyIDEyIDJ6bTAgMThjLTQuNDEgMC04LTMuNTktOC04czMuNTktOCA4LTggOCAzLjU5IDggOC0zLjU5IDgtOCA4eiIgZmlsbD0iIzQyODVGNCIvPjwvc3ZnPg==",

  "connection": {
    "type": "basic",
    "fields": [
      {
        "name": "url",
        "type": "text",
        "label": "HeliosDB URL",
        "required": true,
        "help": "Your HeliosDB instance URL"
      },
      {
        "name": "api_key",
        "type": "text",
        "label": "API Key",
        "required": false,
        "help": "API key for authentication (if enabled)"
      }
    ],
    "test": {
      "url": "/health",
      "method": "GET"
    }
  },

  "modules": {
    "execute_query": {
      "label": "Execute SQL Query",
      "description": "Execute a SQL query and return results",
      "connection": true,

      "parameters": [
        {
          "name": "sql",
          "type": "text",
          "label": "SQL Query",
          "required": true
        },
        {
          "name": "branch",
          "type": "text",
          "label": "Branch",
          "default": "main"
        }
      ],

      "communication": {
        "url": "/v1/branches/{{parameters.branch}}/query",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "sql": "{{parameters.sql}}",
          "params": []
        }
      },

      "output": [
        {
          "name": "rows",
          "type": "array",
          "label": "Rows"
        },
        {
          "name": "columns",
          "type": "array",
          "label": "Columns"
        }
      ]
    },

    "insert_row": {
      "label": "Insert Row",
      "description": "Insert a new row into a table",
      "connection": true,

      "parameters": [
        {
          "name": "table",
          "type": "text",
          "label": "Table Name",
          "required": true
        },
        {
          "name": "data",
          "type": "collection",
          "label": "Row Data",
          "required": true,
          "spec": []
        },
        {
          "name": "branch",
          "type": "text",
          "label": "Branch",
          "default": "main"
        }
      ],

      "communication": {
        "url": "/v1/branches/{{parameters.branch}}/tables/{{parameters.table}}/data",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "rows": ["{{parameters.data}}"]
        }
      }
    },

    "vector_search": {
      "label": "Vector Search",
      "description": "Search for similar documents using semantic search",
      "connection": true,

      "parameters": [
        {
          "name": "store_name",
          "type": "text",
          "label": "Vector Store",
          "required": true
        },
        {
          "name": "query",
          "type": "text",
          "label": "Search Query",
          "required": true
        },
        {
          "name": "top_k",
          "type": "integer",
          "label": "Max Results",
          "default": 10
        },
        {
          "name": "min_score",
          "type": "number",
          "label": "Minimum Score",
          "default": 0.7
        }
      ],

      "communication": {
        "url": "/v1/vectors/stores/{{parameters.store_name}}/search/text",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "text": "{{parameters.query}}",
          "top_k": "{{parameters.top_k}}",
          "min_score": "{{parameters.min_score}}"
        }
      },

      "output": [
        {
          "name": "results",
          "type": "array",
          "label": "Search Results",
          "spec": [
            {
              "name": "id",
              "type": "text",
              "label": "Document ID"
            },
            {
              "name": "score",
              "type": "number",
              "label": "Similarity Score"
            },
            {
              "name": "content",
              "type": "text",
              "label": "Content"
            },
            {
              "name": "metadata",
              "type": "collection",
              "label": "Metadata"
            }
          ]
        }
      ]
    },

    "store_text": {
      "label": "Store Text with Embedding",
      "description": "Store text with automatic vector embedding",
      "connection": true,

      "parameters": [
        {
          "name": "store_name",
          "type": "text",
          "label": "Vector Store",
          "required": true
        },
        {
          "name": "text",
          "type": "text",
          "label": "Text Content",
          "required": true
        },
        {
          "name": "metadata",
          "type": "collection",
          "label": "Metadata",
          "spec": []
        }
      ],

      "communication": {
        "url": "/v1/vectors/stores/{{parameters.store_name}}/texts",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "texts": ["{{parameters.text}}"],
          "metadatas": ["{{parameters.metadata}}"]
        }
      }
    },

    "agent_memory_save": {
      "label": "Save Agent Memory",
      "description": "Save a message to agent conversation memory",
      "connection": true,

      "parameters": [
        {
          "name": "session_id",
          "type": "text",
          "label": "Session ID",
          "required": true
        },
        {
          "name": "role",
          "type": "select",
          "label": "Role",
          "required": true,
          "options": [
            {"label": "User", "value": "user"},
            {"label": "Assistant", "value": "assistant"},
            {"label": "System", "value": "system"}
          ]
        },
        {
          "name": "content",
          "type": "text",
          "label": "Message Content",
          "required": true
        }
      ],

      "communication": {
        "url": "/v1/agents/memory/{{parameters.session_id}}/add",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "role": "{{parameters.role}}",
          "content": "{{parameters.content}}"
        }
      }
    },

    "agent_memory_load": {
      "label": "Load Agent Memory",
      "description": "Load conversation memory for an agent session",
      "connection": true,

      "parameters": [
        {
          "name": "session_id",
          "type": "text",
          "label": "Session ID",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "label": "Message Limit",
          "default": 50
        }
      ],

      "communication": {
        "url": "/v1/agents/memory/{{parameters.session_id}}/messages?limit={{parameters.limit}}",
        "method": "GET",
        "headers": {
          "X-API-Key": "{{connection.api_key}}"
        }
      },

      "output": [
        {
          "name": "messages",
          "type": "array",
          "label": "Messages"
        }
      ]
    },

    "create_branch": {
      "label": "Create Branch",
      "description": "Create a new database branch",
      "connection": true,

      "parameters": [
        {
          "name": "name",
          "type": "text",
          "label": "Branch Name",
          "required": true
        },
        {
          "name": "from_branch",
          "type": "text",
          "label": "Source Branch",
          "default": "main"
        }
      ],

      "communication": {
        "url": "/v1/branches",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "name": "{{parameters.name}}",
          "from_branch": "{{parameters.from_branch}}"
        }
      }
    },

    "merge_branch": {
      "label": "Merge Branch",
      "description": "Merge a branch into another",
      "connection": true,

      "parameters": [
        {
          "name": "source_branch",
          "type": "text",
          "label": "Source Branch",
          "required": true
        },
        {
          "name": "target_branch",
          "type": "text",
          "label": "Target Branch",
          "default": "main"
        }
      ],

      "communication": {
        "url": "/v1/branches/{{parameters.source_branch}}/merge",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "target": "{{parameters.target_branch}}"
        }
      }
    },

    "time_travel_query": {
      "label": "Time Travel Query",
      "description": "Query data at a specific point in time",
      "connection": true,

      "parameters": [
        {
          "name": "sql",
          "type": "text",
          "label": "SQL Query",
          "required": true
        },
        {
          "name": "timestamp",
          "type": "date",
          "label": "Point in Time",
          "required": true
        },
        {
          "name": "branch",
          "type": "text",
          "label": "Branch",
          "default": "main"
        }
      ],

      "communication": {
        "url": "/v1/branches/{{parameters.branch}}/query",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "sql": "{{parameters.sql}}",
          "as_of_timestamp": "{{parameters.timestamp}}"
        }
      }
    },

    "create_vector_store": {
      "label": "Create Vector Store",
      "description": "Create a new vector store for embeddings",
      "connection": true,

      "parameters": [
        {
          "name": "name",
          "type": "text",
          "label": "Store Name",
          "required": true
        },
        {
          "name": "dimensions",
          "type": "integer",
          "label": "Vector Dimensions",
          "default": 1536
        },
        {
          "name": "metric",
          "type": "select",
          "label": "Distance Metric",
          "default": "cosine",
          "options": [
            {"label": "Cosine", "value": "cosine"},
            {"label": "Euclidean", "value": "euclidean"},
            {"label": "Dot Product", "value": "dot"}
          ]
        }
      ],

      "communication": {
        "url": "/v1/vectors/stores",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "name": "{{parameters.name}}",
          "dimensions": "{{parameters.dimensions}}",
          "metric": "{{parameters.metric}}"
        }
      }
    }
  },

  "triggers": {
    "new_row": {
      "label": "New Row",
      "description": "Triggers when a new row is added to a table",
      "connection": true,
      "type": "polling",

      "parameters": [
        {
          "name": "table",
          "type": "text",
          "label": "Table",
          "required": true
        },
        {
          "name": "branch",
          "type": "text",
          "label": "Branch",
          "default": "main"
        }
      ],

      "communication": {
        "url": "/v1/branches/{{parameters.branch}}/query",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-API-Key": "{{connection.api_key}}"
        },
        "body": {
          "sql": "SELECT * FROM {{parameters.table}} ORDER BY id DESC LIMIT 100"
        }
      }
    }
  }
}
