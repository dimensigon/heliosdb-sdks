{
  "name": "heliosdb-vscode",
  "displayName": "HeliosDB",
  "description": "HeliosDB integration for VS Code - AI-native database with vector search, branching, and agent memory",
  "version": "2.8.0",
  "publisher": "heliosdb",
  "license": "AGPL-3.0-only",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dimensigon/heliosdb-sdks"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "database",
    "sql",
    "vector-database",
    "ai",
    "embeddings",
    "heliosdb"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onCommand:heliosdb.connect",
    "onView:heliosdb-explorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "heliosdb.connect",
        "title": "Connect to HeliosDB",
        "category": "HeliosDB"
      },
      {
        "command": "heliosdb.disconnect",
        "title": "Disconnect from HeliosDB",
        "category": "HeliosDB"
      },
      {
        "command": "heliosdb.executeQuery",
        "title": "Execute SQL Query",
        "category": "HeliosDB",
        "icon": "$(play)"
      },
      {
        "command": "heliosdb.explainQuery",
        "title": "Explain Query Plan",
        "category": "HeliosDB"
      },
      {
        "command": "heliosdb.createBranch",
        "title": "Create Branch",
        "category": "HeliosDB",
        "icon": "$(git-branch)"
      },
      {
        "command": "heliosdb.switchBranch",
        "title": "Switch Branch",
        "category": "HeliosDB"
      },
      {
        "command": "heliosdb.mergeBranch",
        "title": "Merge Branch",
        "category": "HeliosDB"
      },
      {
        "command": "heliosdb.vectorSearch",
        "title": "Vector Search",
        "category": "HeliosDB",
        "icon": "$(search)"
      },
      {
        "command": "heliosdb.nlQuery",
        "title": "Natural Language Query",
        "category": "HeliosDB",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "heliosdb.refreshExplorer",
        "title": "Refresh Explorer",
        "category": "HeliosDB",
        "icon": "$(refresh)"
      },
      {
        "command": "heliosdb.exportData",
        "title": "Export Data",
        "category": "HeliosDB"
      },
      {
        "command": "heliosdb.importData",
        "title": "Import Data",
        "category": "HeliosDB"
      },
      {
        "command": "heliosdb.showTimeline",
        "title": "Show Timeline",
        "category": "HeliosDB"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "heliosdb",
          "title": "HeliosDB",
          "icon": "images/activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "heliosdb": [
        {
          "id": "heliosdb-connections",
          "name": "Connections"
        },
        {
          "id": "heliosdb-explorer",
          "name": "Explorer"
        },
        {
          "id": "heliosdb-branches",
          "name": "Branches"
        },
        {
          "id": "heliosdb-vectors",
          "name": "Vector Stores"
        },
        {
          "id": "heliosdb-history",
          "name": "Query History"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "heliosdb-connections",
        "contents": "No HeliosDB connections.\n[Add Connection](command:heliosdb.connect)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "heliosdb.refreshExplorer",
          "when": "view == heliosdb-explorer",
          "group": "navigation"
        },
        {
          "command": "heliosdb.createBranch",
          "when": "view == heliosdb-branches",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "heliosdb.executeQuery",
          "when": "view == heliosdb-explorer && viewItem == table"
        },
        {
          "command": "heliosdb.switchBranch",
          "when": "view == heliosdb-branches && viewItem == branch"
        },
        {
          "command": "heliosdb.mergeBranch",
          "when": "view == heliosdb-branches && viewItem == branch"
        },
        {
          "command": "heliosdb.vectorSearch",
          "when": "view == heliosdb-vectors && viewItem == vectorStore"
        }
      ],
      "editor/context": [
        {
          "command": "heliosdb.executeQuery",
          "when": "editorLangId == sql",
          "group": "heliosdb@1"
        },
        {
          "command": "heliosdb.explainQuery",
          "when": "editorLangId == sql",
          "group": "heliosdb@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "heliosdb.executeQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorLangId == sql && heliosdb.connected"
      },
      {
        "command": "heliosdb.nlQuery",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "heliosdb.connected"
      }
    ],
    "configuration": {
      "title": "HeliosDB",
      "properties": {
        "heliosdb.connections": {
          "type": "array",
          "default": [],
          "description": "Saved HeliosDB connections",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Connection name"
              },
              "url": {
                "type": "string",
                "description": "HeliosDB URL"
              },
              "apiKey": {
                "type": "string",
                "description": "API key (optional)"
              }
            }
          }
        },
        "heliosdb.defaultBranch": {
          "type": "string",
          "default": "main",
          "description": "Default branch to use"
        },
        "heliosdb.autoExecute": {
          "type": "boolean",
          "default": false,
          "description": "Auto-execute queries on save"
        },
        "heliosdb.resultLimit": {
          "type": "number",
          "default": 1000,
          "description": "Maximum rows to display in results"
        },
        "heliosdb.nlQueryProvider": {
          "type": "string",
          "enum": ["openai", "anthropic", "ollama"],
          "default": "openai",
          "description": "LLM provider for natural language queries"
        },
        "heliosdb.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for NL queries"
        },
        "heliosdb.showQueryTime": {
          "type": "boolean",
          "default": true,
          "description": "Show query execution time"
        },
        "heliosdb.formatResults": {
          "type": "string",
          "enum": ["table", "json", "csv"],
          "default": "table",
          "description": "Default result format"
        }
      }
    },
    "languages": [
      {
        "id": "heliosdb-sql",
        "aliases": ["HeliosDB SQL", "hsql"],
        "extensions": [".hsql"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "heliosdb-sql",
        "scopeName": "source.hsql",
        "path": "./syntaxes/hsql.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sql",
        "path": "./snippets/heliosdb.json"
      },
      {
        "language": "heliosdb-sql",
        "path": "./snippets/heliosdb.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
