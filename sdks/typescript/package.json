{
  "name": "@heliosdb/client",
  "version": "3.0.0",
  "description": "Official TypeScript/JavaScript SDK for HeliosDB - AI-native embedded database",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "database",
    "embedded",
    "vector-database",
    "postgresql",
    "ai",
    "langchain",
    "llm",
    "rag",
    "sql",
    "typescript"
  ],
  "author": "HeliosDB Team <support@heliosdb.com>",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dimensigon/heliosdb-sdks"
  },
  "homepage": "https://github.com/Dimensigon/heliosdb-sdks#readme",
  "bugs": {
    "url": "https://github.com/Dimensigon/heliosdb-sdks/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "langchain": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "langchain": {
      "optional": true
    }
  }
}
