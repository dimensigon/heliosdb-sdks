# MANIFEST.in - Specify additional files to include in source distribution

# Include documentation
include README.md
include LICENSE
include CHANGELOG.md

# Include package metadata
include pyproject.toml
include setup.py

# Include installation test
include INSTALLATION_TEST.py

# Include type information
recursive-include heliosdb_sqlite *.py
recursive-include heliosdb_sqlite *.pyi
include heliosdb_sqlite/py.typed

# Include binaries
recursive-include heliosdb_sqlite/binaries *

# Exclude test files from distribution
recursive-exclude tests *
recursive-exclude docs *
recursive-exclude examples *

# Exclude build artifacts
global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.so
global-exclude *.dylib
